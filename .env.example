# Скопируйте в .env и при необходимости переопределите значения.
# Все переменные имеют дефолты — для локального запуска файл не обязателен.
# docker-compose подхватывает .env автоматически.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=db

# Хост БД. Для локального запуска — localhost.
# В docker-compose переопределяется на имя сервиса (postgres).
DB_HOST=localhost

# Веса экстрактора — публичная ссылка Яндекс.Диска.
MODEL_URL=https://disk.yandex.ru/d/6U7YaqjrqGDjYQ
